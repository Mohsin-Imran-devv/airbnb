<%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/nav') %>
  <main class="pb-20 px-4 md:px-8">
    
    <div class="max-w-4xl mx-auto mt-8">
      
      <!-- Image -->
      <div class="relative h-64 md:h-96 rounded-2xl overflow-hidden mb-6">
        <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent"></div>
        <div class="absolute bottom-4 left-4">
          <h1 class="text-white text-3xl md:text-4xl font-bold"><%= home.houseName %></h1>
          <p class="text-gray-300 mt-1">📍 <%= home.location %></p>
        </div>
      </div>

      <!-- Details Card -->
      <div class="bg-[#1A1B26] rounded-2xl p-8 border border-gray-800">
        
        <!-- Price & Rating -->
        <div class="flex flex-wrap justify-between items-center mb-6">
          <div>
            <span class="text-gray-400 text-sm">Price per night</span>
            <div class="text-cyan-400 text-3xl font-bold">Rs. <%= home.price %></div>
          </div>
          <div class="flex items-center gap-2 bg-yellow-500/10 px-4 py-2 rounded-full">
            <span class="text-yellow-400 text-xl">★</span>
            <span class="text-yellow-400 font-bold text-lg"><%= home.rating %></span>
          </div>
        </div>

        <!-- Description -->
        <div class="mb-6">
          <h3 class="text-white font-semibold mb-2">Description</h3>
          <p class="text-gray-400 leading-relaxed"><%= home.description %></p>
        </div>

        <!-- Actions -->
        <div class="flex flex-wrap gap-3">
          <a href="<%= home.pdf %>" target="_blank" rel="noopener"  class="bg-blue-600/20 text-blue-400 hover:bg-blue-600/30 px-5 py-2.5 rounded-xl font-medium text-sm transition-all">
            📄 Download Rules
          </a>
          <form action="/favourites" method="POST" class="inline">
            <input type="hidden" name="id" value="<%= home._id %>">
            <button type="submit" class="bg-pink-600/20 text-pink-400 hover:bg-pink-600/30 px-5 py-2.5 rounded-xl font-medium text-sm transition-all">
              ♥ Add to Favorites
            </button>
          </form>
        </div>

      </div>
    </div>

  </main>
</body>
</html>