<%- include('../partials/head') %>
  <style>
    .list {
      margin-left: 3px;
      margin-right: 3px;
      margin-bottom: 10px;
    }
  </style>
  </head>

  <body class="flex flex-col">
    <%- include('../partials/nav') %>
      <main class="pb-20 px-4 md:px-8">

        <!-- Header Section -->
        <div class="text-center mt-8 mb-10">
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
            🏠 Explore Our <span class="text-blue-400">Featured Homes</span>
          </h1>
          <p class="text-gray-400 text-sm md:text-base">Find your perfect stay from our curated collection</p>
        </div>

        <!-- Homes Grid -->
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 max-w-7xl mt-5 mx-auto">
          <% registeredHome.forEach((home)=> { %>
            <li
              class="group bg-[#1A1B26] list rounded-2xl overflow-hidden border border-gray-800 hover:border-cyan-500/50 transition-all duration-300 hover:shadow-2xl hover:shadow-cyan-500/10 hover:-translate-y-1">

              <!-- Image Container -->
              <div class="relative h-52 overflow-hidden">
                <img src="<%= home.photo %>" alt="<%= home.houseName %>"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                <!-- Price Badge -->
                <div
                  class="absolute top-3 right-3 bg-black/60 backdrop-blur-md text-white px-3 py-1.5 rounded-full text-sm font-bold">
                  Rs. <%= home.price %>
                </div>
              </div>

              <!-- Content -->
              <div class="p-4">
                <h2 class="text-white font-semibold text-lg truncate">
                  <%= home.houseName %>
                </h2>

                <div class="flex items-center gap-1.5 mt-1.5 text-gray-400 text-sm">
                  <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                  </svg>
                  <span>
                    <%= home.location %>
                  </span>
                </div>

                <div class="flex items-center gap-1 mt-2">
                  <span class="text-yellow-400 text-sm">★</span>
                  <span class="text-gray-300 text-sm font-medium">
                    <%= home.rating %>
                  </span>
                </div>

                <!-- Actions -->
                <div class="mt-4 space-y-2">
                  <% if (!isLoggedIn) { %>
                    <a href="/login"
                      class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl transition-all duration-200 text-sm">
                      Login to Book
                    </a>
                    <% } else if (bookedHomeIds.includes(home._id.toString())) { %>
                      <div
                        class="block w-full text-center bg-green-600/20 text-green-400 p-3 font-medium py-2.5 rounded-xl text-sm border border-green-500/30">
                        ✓ Already Booked
                      </div>
                      <% } else { %>
                        <a href="/confirm-booking/<%= home._id %>"
                          class="block w-full text-center bg-cyan-600 hover:bg-cyan-700 text-white font-medium p-3 rounded-xl transition-all duration-200 text-sm">
                          Book Now
                        </a>
                        <% } %>

                          <a href="/index/<%= home._id %>"
                            class="block w-full mt-1 text-center bg-green-600 hover:bg-green-700 text-white font-medium p-3 rounded-xl transition-all duration-200 text-sm">
                            View Details
                          </a>

                          <a href="/download-pdf/<%= home._id %>"
                            class="block text-center text-blue-400 hover:text-blue-300 text-xs mt-3">
                            📄 Download Rules
                          </a>
                </div>
              </div>
            </li>
            <% }); %>
        </ul>

      </main>
  </body>

  </html>