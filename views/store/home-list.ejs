<%- include('../partials/head') %>
<style>
  .list{
    margin-left: 3px; 
    margin-right: 3px;
    margin-bottom: 10px;
  }
</style>
</head>

<body class="flex flex-col">
  <%- include('../partials/nav') %>
  <main class="pb-20 px-4 md:px-8">
    
    <!-- Header -->
    <div class="text-center mt-8 mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
        🏡 All <span class="text-cyan-400">Registered Homes</span>
      </h1>
      <p class="text-gray-400 text-sm">Browse through our complete collection</p>
    </div>

    <!-- Grid -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 max-w-7xl mt-5 mx-auto">
      <% registeredHome.forEach((home)=> { %>
        <li class="group list bg-[#1A1B26] rounded-2xl overflow-hidden border border-gray-800 hover:border-cyan-500/50 transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
          
          <!-- Image -->
          <div class="relative h-52 overflow-hidden">
            <img src="<%= home.photo %>" alt="<%= home.houseName %>" 
                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
            <div class="absolute top-3 left-3 bg-cyan-500/90 text-black px-2.5 py-1 rounded-full text-xs font-bold">
              ★ <%= home.rating %>
            </div>
          </div>

          <!-- Info -->
          <div class="p-4">
            <h2 class="text-white font-semibold text-lg truncate"><%= home.houseName %></h2>
            <p class="text-gray-400 text-sm mt-1 flex items-center gap-1">
              <span>📍</span> <%= home.location %>
            </p>
            
            <div class="flex justify-between items-center mt-3 pt-3 border-t border-gray-700">
              <span class="text-cyan-400 font-bold text-xl">Rs. <%= home.price %></span>
              <span class="text-gray-500 text-xs">/night</span>
            </div>

            <div class="mt-4 space-y-2">
               <a href="/index/<%= home._id %>" class="block w-full mt-1 text-center mb-3 bg-green-600 hover:bg-green-700 text-white font-medium p-3 rounded-xl transition-all duration-200 text-sm">
                View Details
              </a>
              <a href="<%= home.pdf %>" target="_blank" rel="noopener"  class="block text-center text-blue-400 hover:text-blue-300 text-xs">📄 Download Rules</a>
            </div>
          </div>
        </li>
      <% }); %>
    </ul>

  </main>
</body>
</html>