<%- include('../partials/head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: #11121A;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #ffffff;
        line-height: 1.6;
        min-height: 100vh;
    }

    /* Modern scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #1E1F2B;
    }

    ::-webkit-scrollbar-thumb {
        background: #3B3E4E;
        border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: #4F5366;
    }

    main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    /* Header Section */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #ffffff 0%, #A5B4FC 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.5px;
    }

    .stats-badge {
        background: rgba(165, 180, 252, 0.1);
        border: 1px solid rgba(165, 180, 252, 0.2);
        border-radius: 100px;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        backdrop-filter: blur(10px);
    }

    .stats-badge i {
        color: #A5B4FC;
        font-size: 1.25rem;
    }

    .stats-badge span {
        color: #ffffff;
        font-weight: 500;
    }

    .stats-badge strong {
        color: #A5B4FC;
        font-size: 1.25rem;
        margin-left: 0.25rem;
    }

    /* Empty State */
    .empty-state {
        background: linear-gradient(145deg, #1A1B26, #151620);
        border-radius: 32px;
        padding: 4rem 2rem;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .empty-state-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, rgba(165, 180, 252, 0.1), rgba(255, 255, 255, 0.05));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        border: 2px solid rgba(165, 180, 252, 0.2);
    }

    .empty-state-icon i {
        font-size: 3rem;
        color: #A5B4FC;
    }

    .empty-state h3 {
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #ffffff;
    }

    .empty-state p {
        color: #8F95B2;
        font-size: 1.1rem;
        max-width: 300px;
        margin: 0 auto;
    }

    /* Bookings Grid */
    .bookings-grid {
        display: grid;
        gap: 1.5rem;
    }

    /* Booking Card */
    .booking-card {
        background: linear-gradient(145deg, #1A1B26, #151620);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .booking-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #A5B4FC, #818CF8);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .booking-card:hover {
        transform: translateY(-4px);
        border-color: rgba(165, 180, 252, 0.3);
        box-shadow: 0 25px 40px -15px rgba(0, 0, 0, 0.5);
    }

    .booking-card:hover::before {
        opacity: 1;
    }

    .card-content {
        padding: 1.75rem;
    }

    /* Card Header */
    .card-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .home-info h2 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 0.5rem;
        letter-spacing: -0.3px;
    }

    .location {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #8F95B2;
        font-size: 0.95rem;
    }

    .location i {
        color: #A5B4FC;
    }

    /* Status Badge */
    .status-badge {
        padding: 0.5rem 1.25rem;
        border-radius: 100px;
        font-size: 0.9rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(34, 197, 94, 0.1);
        color: #4ADE80;
        border: 1px solid rgba(34, 197, 94, 0.2);
    }

    .status-badge i {
        font-size: 0.8rem;
    }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .detail-section {
        background: rgba(0, 0, 0, 0.2);
        border-radius: 20px;
        padding: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .section-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #8F95B2;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .section-title i {
        color: #A5B4FC;
    }

    .info-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .info-item {
        display: flex;
        align-items: flex-start; /* Changed from center to flex-start */
        gap: 0.75rem;
        color: #ffffff;
        font-size: 1rem;
        width: 100%;
    }

    .info-item i {
        width: 20px;
        color: #A5B4FC;
        font-size: 1rem;
        flex-shrink: 0; /* Prevent icon from shrinking */
        margin-top: 3px; /* Align with text */
    }

    .info-item .label {
        color: #8F95B2;
        min-width: 70px;
        flex-shrink: 0; /* Prevent label from shrinking */
    }

    .info-item .value {
        color: #ffffff;
        font-weight: 500;
        word-break: break-word; /* Break long words */
        overflow-wrap: break-word; /* Handle long strings */
        hyphens: auto; /* Add hyphens if needed */
        flex: 1; /* Take remaining space */
    }

    /* Email specific styling */
    .info-item .value.email-value {
        font-size: 0.95rem; /* Slightly smaller for email */
        color: #A5B4FC; /* Different color for email */
        word-break: break-all; /* Break email at any point if needed */
    }

    /* Price Tag */
    .price-tag {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .price-label {
        color: #8F95B2;
        font-size: 0.9rem;
    }

    .price-amount {
        font-size: 1.5rem;
        font-weight: 700;
        color: #A5B4FC;
        letter-spacing: -0.5px;
    }

    /* Responsive Design */
    @media (max-width: 640px) {
        .page-title {
            font-size: 1.5rem;
            text-align: center;
        }

        .card-content {
            padding: 1.25rem;
        }

        .home-info h2 {
            font-size: 1.25rem;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .stats-badge {
            width: 100%;
            justify-content: center;
        }

        .info-item {
            flex-wrap: wrap; /* Allow wrapping on mobile */
        }
        
        .info-item .label {
            min-width: 60px; /* Smaller label on mobile */
        }
        
        .info-item .value {
            width: calc(100% - 95px); /* Calculate width for mobile */
        }
        
        .info-item .value.email-value {
            font-size: 0.85rem; /* Even smaller on mobile */
        }
    }

    /* Loading Animation */
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .loading {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    /* Guest Avatar */
    .guest-avatar {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #A5B4FC, #818CF8);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #11121A;
        font-weight: 600;
        font-size: 0.9rem;
    }
</style>
</head>

<body>
  <%- include('../partials/nav') %>
  
  <main>
    <div class="page-header">
      <h1 align="center" class="page-title">
        <i class="fas fa-home" style="background: none; -webkit-text-fill-color: #A5B4FC; margin-right: 1rem;"></i>
        My Homes Bookings
      </h1>
      <% if (bookings.length > 0) { %>
        <div class="stats-badge">
          <i class="fas fa-calendar-check"></i>
          <span>Total Bookings <strong><%= bookings.length %></strong></span>
        </div>
      <% } %>
    </div>
    
    <% if (bookings.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <i class="fas fa-calendar-times"></i>
        </div>
        <h3>No bookings yet</h3>
        <p>Your homes haven't received any bookings at the moment</p>
      </div>
    <% } else { %>
      <div class="bookings-grid">
        <% bookings.forEach(booking => { %>
          <div class="booking-card">
            <div class="card-content">
              <!-- Card Header -->
              <div class="card-header">
                <div class="home-info">
                  <h2>
                    <i class="fas fa-building" style="color: #A5B4FC; margin-right: 0.5rem;"></i>
                    <%= booking.homeId.houseName %>
                  </h2>
                  <div class="location">
                    <i class="fas fa-map-marker-alt"></i>
                    <span><%= booking.homeId.location %></span>
                  </div>
                </div>
                
                <span class="status-badge">
                  <i class="fas fa-circle"></i>
                  <%= booking.status %>
                </span>
              </div>
              
              <!-- Details Grid -->
              <div class="details-grid">
                <!-- Guest Details -->
                <div class="detail-section">
                  <div class="section-title">
                    <i class="fas fa-user"></i>
                    <span>Guest Details</span>
                  </div>
                  <div class="info-list">
                    <div class="info-item">
                      <i class="fas fa-user-circle"></i>
                      <span class="label">Name:</span>
                      <span class="value"><%= booking.userName %></span>
                    </div>
                    <div class="info-item">
                      <i class="fas fa-envelope"></i>
                      <span class="label">Email:</span>
                      <span class="value email-value"><%= booking.userEmail %></span>
                    </div>
                    <div class="info-item">
                      <i class="fas fa-users"></i>
                      <span class="label">Guests:</span>
                      <span class="value"><%= booking.guests %> guest(s)</span>
                    </div>
                  </div>
                </div>
                
                <!-- Booking Details -->
                <div class="detail-section">
                  <div class="section-title">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Booking Details</span>
                  </div>
                  <div class="info-list">
                    <div class="info-item">
                      <i class="fas fa-calendar-check"></i>
                      <span class="label">Check-in:</span>
                      <span class="value"><%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                    <div class="info-item">
                      <i class="fas fa-calendar-times"></i>
                      <span class="label">Check-out:</span>
                      <span class="value"><%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                    <div class="info-item">
                      <i class="fas fa-clock"></i>
                      <span class="label">Booked:</span>
                      <span class="value"><%= new Date(booking.bookingDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                  </div>
                  
                  <div class="price-tag">
                    <span class="price-label">Total Amount</span>
                    <span class="price-amount">Rs. <%= booking.totalPrice.toLocaleString() %></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</body>
</html>