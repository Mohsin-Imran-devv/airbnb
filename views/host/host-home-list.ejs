<%- include('../partials/head') %>
<style>
  .list{
    margin-left: 3px; 
    margin-right: 3px;
    margin-bottom: 10px;
  }
</style>
</head>

<body>
  <%- include('../partials/nav') %>
  <main class="px-4 md:px-8 pb-20">
    
    <!-- Header -->
    <div class="text-center mt-8 mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-white">Hey Host! 👋</h1>
      <p class="text-gray-400 mt-2">Here are your registered homes</p>
    </div>

    <% if (registeredHome && registeredHome.length > 0) { %>
    <!-- Grid -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mt-5">
      <% registeredHome.forEach((home)=> { %>
        <li class="bg-[#1A1B26] list rounded-2xl overflow-hidden border mx-4 border-gray-800 hover:border-cyan-500/50 transition-all duration-300 group">
          
          <!-- Image -->
          <div class="relative h-52 overflow-hidden">
            <img src="<%= home.photo %>" alt="<%= home.houseName %>" 
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          </div>

          <!-- Content -->
          <div class="p-5">
            <h2 class="text-white font-bold text-xl mb-1"><%= home.houseName %></h2>
            <p class="text-gray-400 text-sm flex items-center gap-1 mb-2">
              <span>📍</span> <%= home.location %>
            </p>
            <p class="text-gray-500 text-sm line-clamp-2"><%= home.description %></p>
            
            <!-- Price & Rating -->
            <div class="flex justify-between items-center mt-4 pt-4 border-t border-gray-700">
              <span class="text-cyan-400 font-bold text-2xl">Rs. <%= home.price %></span>
              <span class="bg-yellow-500/10 text-yellow-400 px-3 py-1 rounded-full text-sm font-medium">
                ★ <%= home.rating %>
              </span>
            </div>

            <!-- Buttons -->
            <div class="mt-4 space-y-2">
              <a href="/host/edit-home/<%=home._id%>?editing=true" 
                 class="block w-full text-center bg-blue-600 hover:bg-blue-700 p-3 text-white font-medium py-2.5 rounded-xl transition-all text-sm">
                ✏️ Edit
              </a>
              <form action="/host/delete-home/<%= home._id %>" method="POST">
                <button type="submit" 
                        class="w-full bg-red-500/10 hover:bg-red-500/20 p-3 mt-1 cursor-pointer text-red-400 border border-red-500/30 font-medium py-2.5 rounded-xl transition-all text-sm">
                  🗑️ Delete
                </button>
              </form>
            </div>
          </div>
        </li>
      <% }); %>
    </ul>

    <% } else { %>
      <!-- Empty State -->
      <div class="text-center mt-20">
        <div class="text-2xl mb-4">🏠</div>
        <p class="text-gray-400 text-2xl mb-6">No homes added yet!</p>
        <a href="/host/add-home" 
           class="inline-block bg-cyan-600 p-3 hover:bg-cyan-700 text-white font-semibold py-3 px-8 rounded-xl transition-all">
           Add Your First Home
        </a>
      </div>
    <% } %>

    <!-- Add Home Button -->
    <% if (registeredHome && registeredHome.length > 0) { %>
    <div class="text-center mt-12">
      <a href="/host/add-home" 
         class="inline-block p-3 mt-3 bg-cyan-600 hover:bg-cyan-700 text-white font-semibold py-3 px-8 rounded-xl transition-all">
         Add New Home
      </a>
    </div>
    <% } %>

  </main>
</body>
</html>